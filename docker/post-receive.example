#!/usr/bin/env bash
#
# Sunstone Web — post-receive hook for the "host bare repo" deploy.
#
# Push to a bare repo on the host; this hook checks the pushed ref out, IN PLACE,
# into the folder Sunstone Web bind-mounts read-only. The git metadata lives in
# the bare repo (GIT_DIR), NOT in the work-tree, so the served folder holds only
# content files — Sunstone's watcher fires on the rewritten files and pushes the
# change to every connected browser instantly. No sidecar, no polling.
#
# INSTALL (on the host that serves the wiki):
#
#   # 1. A bare repo to push to, and the work-tree Sunstone will serve.
#   git init --bare /srv/wiki.git
#   mkdir -p /srv/wiki
#
#   # 2. Install this hook.
#   install -m 0755 post-receive.example /srv/wiki.git/hooks/post-receive
#   #   (edit DEPLOY_REF / WORK_TREE below if your branch or path differ)
#
#   # 3. Point Sunstone Web at the work-tree (base compose, folder mount):
#   SUNSTONE_BUNDLE_HOST=/srv/wiki SUNSTONE_WEB_PORT=8080 \
#     docker compose up -d
#
#   # 4. From anywhere with SSH to the host:
#   git remote add wiki ssh://user@host/srv/wiki.git
#   git push wiki main         # every push updates the live viewer
#
# The push-time checkout is what makes reload instant; a browser open on the
# viewer sees the edit without reloading.

set -euo pipefail

# --- config: adjust to taste --------------------------------------------------
GIT_DIR_ABS="$(git rev-parse --git-dir)"
GIT_DIR_ABS="$(cd "$GIT_DIR_ABS" && pwd)"
WORK_TREE="${SUNSTONE_WORK_TREE:-/srv/wiki}"   # folder Sunstone mounts :ro
DEPLOY_REF="${SUNSTONE_DEPLOY_REF:-refs/heads/main}"  # ref to publish
# ------------------------------------------------------------------------------

while read -r _oldrev _newrev refname; do
  if [ "$refname" = "$DEPLOY_REF" ]; then
    echo "post-receive: publishing $refname -> $WORK_TREE"
    mkdir -p "$WORK_TREE"
    # -f: overwrite the work-tree to match the pushed ref. GIT_DIR stays in the
    # bare repo, so $WORK_TREE never gets a .git dir (no watcher noise).
    git --git-dir="$GIT_DIR_ABS" --work-tree="$WORK_TREE" checkout -f "${DEPLOY_REF#refs/heads/}" -- .
  else
    echo "post-receive: ignoring $refname (not $DEPLOY_REF)"
  fi
done
